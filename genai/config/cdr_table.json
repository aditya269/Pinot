{
  "tableName": "cdr_data",
  "tableType": "REALTIME",
  "segmentsConfig": {
    "schemaName": "cdr_data",
    "replicasPerPartition": "1",
    "retentionTimeUnit": "DAYS",
    "retentionTimeValue": "60",
    "timeType": "DAYS",
    "segmentAssignmentStrategy": "BalanceNumSegmentAssignmentStrategy",
    "timeColumnName": "eventDate",
    "completionConfig": {
      "completionMode": "DOWNLOAD"
    },
    "minimizeDataMovement": false
  },
  "tenants": {
    "broker": "DefaultTenant",
    "server": "DefaultTenant"
  },
  "tableIndexConfig": {
    "enableDefaultStarTree": false,
    "starTreeIndexConfigs": [
      {
        "dimensionsSplitOrder": [
          "accountId",
          "accountName",
          "imsi",
          "distributor",
          "distributorId",
          "customerGroup",
          "customer",
          "customerId",
          "customerReference",
          "msisdn",
          "subscriberId",
          "iccid",
          "retailCurrency",
          "buyCurrency",
          "chargeCurrency",
          "carrier",
          "serviceType",
          "eventDate"
        ],
        "functionColumnPairs": [
          "SUM__BuyAmount",
          "SUM__RetailAmount",
          "SUM__ChargeAmount",
          "SUM__ChargeBalance",
          "SUM__UsageKB",
          "SUM__UsageMB",
          "SUM__Bytes",
          "SUM__SessionDurationMinutes"
        ],
        "maxLeafRecords": 1000
      }
    ],
    "enableDynamicStarTreeCreation": false,
    "aggregateMetrics": true,
    "nullHandlingEnabled": false,
    "columnMajorSegmentBuilderEnabled": true,
    "optimizeDictionary": false,
    "optimizeDictionaryForMetrics": false,
    "optimizeDictionaryType": false,
    "noDictionarySizeRatioThreshold": 0.85,
    "autoGeneratedInvertedIndex": false,
    "createInvertedIndexDuringSegmentGeneration": true,
    "loadMode": "MMAP",
    "rangeIndexVersion": 2,
    "streamConfigs": {
      "streamType": "kafka",
      "realtime.segment.flush.threshold.rows": "200000",
      "realtime.segment.flush.threshold.time": "1d",
      "stream.kafka.consumer.type": "lowlevel",
      "stream.kafka.topic.name": "cdr_data",
      "stream.kafka.decoder.class.name": "org.apache.pinot.plugin.stream.kafka.KafkaJSONMessageDecoder",
      "stream.kafka.consumer.factory.class.name": "org.apache.pinot.plugin.stream.kafka20.KafkaConsumerFactory",
      "stream.kafka.broker.list": "kafka:9092",
      "stream.kafka.consumer.prop.auto.offset.reset": "smallest",
      "stream.kafka.decoder.prop.failOnUnknownField": "false",
      "stream.kafka.decoder.prop.allowNullFields": "true",
      "stream.kafka.consumer.prop.fetch.max.wait.ms": "1000"
    },
    "invertedIndexColumns": [
      "accountName",
      "distributor",
      "iccid",
      "customerGroup",
      "subscriberId",
      "eventDate",
      "imsi",
      "msisdn",
      "carrier",
      "serviceType",
      "customerId",
      "distributorId"
    ],
    "noDictionaryColumns": [
      "BuyAmount",
      "RetailAmount",
      "ChargeAmount",
      "ChargeBalance",
      "UsageKB",
      "UsageMB",
      "Bytes",
      "SessionDurationMinutes"
    ],
    "bloomFilterColumns": [
      "imsi",
      "msisdn"
    ],
    "rangeIndexColumns": [
      "eventDate"
    ],
    "sortedColumn": [
      "accountId"
    ]
  },
  "metadata": {
    "customConfigs": {}
  },
  "routing": {},
  "ingestionConfig": {
    "continueOnError": false,
    "rowTimeValueCheck": false,
    "segmentTimeValueCheck": true,
    "transformConfigs": [
      {
        "columnName": "UsageKB",
        "transformFunction": "roundDecimal(MULT(DIV(Bytes, 1024), 1.0), 5)"
      },
      {
        "columnName": "UsageMB",
        "transformFunction": "roundDecimal(MULT(DIV(Bytes, 1048576), 1.0), 6)"
      },
      {
        "columnName": "SessionDurationMinutes",
        "transformFunction": "DIV(SessionDuration, 60)"
      }
    ]
  },
  "isDimTable": false
}
